{
  "manifest_version": 3,
  "name": "Family Recipe Clipper",
  "version": "1.0.0",
  "description": "Clip ingredients, times, and cooking instructions from any site directly into your family recipe book in one tap!",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://api.github.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
